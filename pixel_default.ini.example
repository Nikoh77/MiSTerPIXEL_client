; PIXEL client config — copy to "pixel_default.ini" next to pixel.py and fill in.
; (holds your API key: keep it out of version control.)
;
; A second file, pixel_remote.ini, is written automatically when you change
; settings from the web UI and OVERRIDES the values here (it's read after this
; one). You normally edit only this file by hand. Server address, API key and
; web_port are local-only: they can never be changed from the web.
[pixel]
; API key recognised by the server
key = r76f87g989_=*3gGDF

; Default server, so you can run pixel.py with no -a flag. Format: host[:port]
server = 192.168.1.10:9999

; Translate INTO this language (ISO code)
target_lang = it

; Source language of the game text; "auto" lets the server/VLM detect it
source_lang = auto

; Optional: force the game title when auto-detection (/tmp/CORENAME etc.) misses
; game = Final Fantasy VI

; Identifies the user requesting translations (for the server's per-user
; history/quota). The device is identified automatically (hashed from the
; MiSTer's network MACs), so you only set the user here.
user_id = your-user-id

; Web UI port on the server (the second-screen page). Must match the server's
; [web] port. Used in --watch mode to register and receive capture triggers.
web_port = 8080

; How to capture the frame:
;   fifo = ask the MiSTer firmware to take a native screenshot (PNG) and read
;          it back. Default. Falls back to "mem" if the screenshot doesn't
;          appear within a few seconds.
;   mem  = read raw RGB straight from the scaler shared memory (/dev/mem).
capture_method = fifo

; With capture_method = fifo, delete the firmware's PNG after sending it
; (keeps /media/fat/screenshots/ from filling up and spares the SD card).
delete_screenshot_after = true
